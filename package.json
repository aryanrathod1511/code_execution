{
  "name": "code-executor-backend-ts",
  "version": "1.0.0",
  "description": "TypeScript clean-architecture remote code execution backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "dev": "nodemon --watch src -e ts --exec \"node --env-file=.env -r ts-node/register src/index.ts\"",
    "worker:dev": "nodemon --watch src -e ts --exec \"node --env-file=.env -r ts-node/register src/worker.ts\"",
    "worker:start": "node --env-file=.env dist/worker.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dockerode": "^4.0.2",
    "express": "^4.19.2",
    "tar-stream": "^3.1.7",
    "ws": "^8.17.0",
    "bullmq": "^5.8.3",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/dockerode": "latest",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/tar-stream": "^3.1.4",
    "@types/ws": "^8.5.10",
    "nodemon": "^3.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  },
  "license": "MIT"
}
